{
    "name": "Primus Tech Labs",
    "version": 2,
    "builds": [
        {
            "src": "index.html",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "index.html",
            "status": 200
        },
        {
            "src": "/.*",
            "methods": [
                "GET",
                "HEAD"
            ],
            "dest": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/.*",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=3600, s-maxage=3600"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                }
            ]
        },
        {
            "source": "/(.*)\\.(?:css|js|woff|woff2|ttf|otf|eot|svg)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ],
    "env": {
        "REGION": "auto"
    },
    "public": true
}